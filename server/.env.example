# Server Port configuration
PORT=5000

# MongoDB Connection String (Local fallback or Mongo Atlas cloud URL)
MONGO_URI=mongodb://127.0.0.1:27017/portfolio

# JWT token signature secret keys
JWT_SECRET=portfolio-super-secret-key-12345

# Application Environment Mode (development | production)
NODE_ENV=development

# Frontend Client URL mapping for CORS origins
CLIENT_URL=http://localhost:5173

# Nodemailer SMTP Configuration (e.g. Mailtrap or Gmail)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM="Awais Ali Portfolio" <portfolio@example.com>
ADMIN_EMAIL=awais.ali@example.com
